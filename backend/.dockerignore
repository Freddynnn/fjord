# Ignore node_modules (dependencies will be installed in the container)
node_modules/

# Ignore environment files (you'll use environment variables in Docker or CI/CD)
.env

# Ignore build outputs (if any, like compiled files)
build/
dist/

# Ignore version control files
.git/
.gitignore

# Ignore IDE/editor config files
.vscode/
.idea/

# Ignore logs or temp files
npm-debug.log
yarn-error.log
*.log

# Ignore any OS-specific files
.DS_Store
Thumbs.db
